{
  "manifest_version": 3,
  "name": "Gmail Anti-Spoof",
  "version": "1.0.0",
  "description": "Prevents email spoofing through unique code generation and WhatsApp-based verification.",
  "permissions": [
    "scripting",
    "clipboardWrite",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://*.ngrok.io/*",
    "https://*.ngrok-free.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js", "sender.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
