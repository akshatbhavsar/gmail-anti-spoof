# Gmail Anti-Spoof – Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── Flask ──────────────────────────────────────────────────────────────────────
# Set to "1" to enable Flask debug mode (development only)
FLASK_DEBUG=0

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://mail.google.com,http://localhost:5000

# ── Fast2SMS WhatsApp Business API ─────────────────────────────────────────────
# Your Fast2SMS API key (from https://www.fast2sms.com/dashboard)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Fast2SMS WhatsApp API endpoint (default shown below)
FAST2SMS_WHATSAPP_URL=https://www.fast2sms.com/dev/whatsapp

# WhatsApp number that will receive the verification code (digits only, no +91)
WHATSAPP_RECIPIENT=9924024265

# Fast2SMS message / template identifiers
# Message ID for the approved WhatsApp template
FAST2SMS_MESSAGE_ID=16753

# Template name as registered in Fast2SMS dashboard
FAST2SMS_TEMPLATE_NAME=project
